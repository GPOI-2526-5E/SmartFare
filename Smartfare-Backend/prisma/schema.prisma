datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   Int       @id @default(autoincrement())
  email                String    @unique @db.VarChar(150)
  passwordHash         String?   @db.VarChar(255)
  authProvider         String    @default("local") @db.VarChar(40)
  sessionId            String?   @db.VarChar(120)
  resetPasswordToken   String?   @db.VarChar(255)
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  profile             UserProfile?
  preferences         UserPreference?
  itineraries         Itinerary[]         @relation("CreatedBy")
  favoriteItineraries ItineraryFavorite[]

  @@index([email])
}

model UserProfile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String?   @db.VarChar(80)
  surname   String?   @db.VarChar(80)
  city      String?   @db.VarChar(80)
  street    String?   @db.VarChar(120)
  avatarUrl String?   @db.VarChar(500)
  birthDate DateTime? @db.Date
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model UserPreference {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetLevelCode    String   @default("MEDIUM") @db.VarChar(20)
  travelStyle        String?  @db.VarChar(40)
  pace               String?  @db.VarChar(40)
  preferredTransport String?  @db.VarChar(40)
  prefersNightlife   Boolean?
  familyFriendly     Boolean?
  maxDailyBudget     Decimal? @db.Decimal(10, 2)
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  interests UserPreferenceInterest[]

  @@index([budgetLevelCode])
}

model UserPreferenceInterest {
  id           Int            @id @default(autoincrement())
  preferenceId Int
  preference   UserPreference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)
  interestCode String         @db.VarChar(40)
  weight       Int            @default(1)

  @@unique([preferenceId, interestCode])
  @@index([interestCode])
}

model GuestSession {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique @db.VarChar(120)
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  ipAddress    String?  @db.VarChar(64)
  userAgent    String?  @db.VarChar(255)

  itineraries Itinerary[]

  @@index([expiresAt])
}

model ItineraryVisibility {
  code        String  @id @db.VarChar(20)
  name        String  @db.VarChar(50)
  description String? @db.VarChar(200)

  itineraries Itinerary[]
}

model Itinerary {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(120)
  description    String?   @db.Text
  isPublished    Boolean   @default(false)
  visibilityCode String    @default("PRIVATE") @db.VarChar(20)
  publicSlug     String?   @unique @db.VarChar(180)
  startDate      DateTime? @db.Date
  endDate        DateTime? @db.Date
  aiPrompt       String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  userId Int?
  user   User? @relation("CreatedBy", fields: [userId], references: [id], onDelete: SetNull)

  guestSessionId Int?
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)

  visibility ItineraryVisibility @relation(fields: [visibilityCode], references: [code])

  items   ItineraryItem[]
  likedBy ItineraryFavorite[]

  @@index([userId])
  @@index([guestSessionId])
  @@index([isPublished])
  @@index([visibilityCode])
  @@index([createdAt])
}

model ItineraryFavorite {
  userId      Int
  itineraryId Int
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@id([userId, itineraryId])
  @@index([itineraryId])
}

model ItineraryItemType {
  code        String  @id @db.VarChar(30)
  label       String  @db.VarChar(50)
  description String? @db.VarChar(200)

  itineraryItems ItineraryItem[]
}

model ItineraryItem {
  id           Int               @id @default(autoincrement())
  itineraryId  Int
  itinerary    Itinerary         @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  itemTypeCode String            @db.VarChar(30)
  itemType     ItineraryItemType @relation(fields: [itemTypeCode], references: [code])

  dayNumber      Int
  orderInt       Int
  title          String?   @db.VarChar(120)
  note           String?   @db.VarChar(400)
  plannedStartAt DateTime?
  plannedEndAt   DateTime?

  activityId Int?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  accommodationId Int?
  accommodation   Accommodation? @relation(fields: [accommodationId], references: [id], onDelete: SetNull)

  routeSegmentId Int?
  routeSegment   RouteSegment? @relation(fields: [routeSegmentId], references: [id], onDelete: SetNull)

  @@unique([itineraryId, dayNumber, orderInt])
  @@index([itineraryId])
  @@index([itemTypeCode])
  @@index([dayNumber])
}

model Location {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(120)
  province  String? @db.VarChar(80)
  cap       String? @db.VarChar(10)
  latitude  Float
  longitude Float

  activities     Activity[]
  accommodations Accommodation[]
  stations       Station[]
  airports       Airport[]
  metroStations  MetroStation[]

  @@index([name])
}

model Accommodation {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(150)
  street     String?  @db.VarChar(150)
  stars      Int      @default(0)
  latitude   Float
  longitude  Float
  imageUrl   String?  @db.VarChar(500)
  locationId Int
  location   Location @relation(fields: [locationId], references: [id])

  itineraryItems ItineraryItem[]

  @@index([locationId])
  @@index([name])
}

model TransportType {
  code        String  @id @db.VarChar(30)
  label       String  @db.VarChar(50)
  description String? @db.VarChar(200)

  transports Transport[]
}

model Transport {
  id            Int           @id @default(autoincrement())
  transportCode String        @unique @db.VarChar(30)
  transportType String        @db.VarChar(30)
  type          TransportType @relation(fields: [transportType], references: [code])

  segments RouteSegment[]

  @@index([transportType])
}

model RouteSegment {
  id                      Int           @id @default(autoincrement())
  transportId             Int
  transport               Transport     @relation(fields: [transportId], references: [id])
  departureAt             DateTime
  arrivalAt               DateTime
  departureStationId      Int?
  departureStation        Station?      @relation("RouteSegmentDepartureStation", fields: [departureStationId], references: [id])
  arrivalStationId        Int?
  arrivalStation          Station?      @relation("RouteSegmentArrivalStation", fields: [arrivalStationId], references: [id])
  departureAirportId      Int?
  departureAirport        Airport?      @relation("RouteSegmentDepartureAirport", fields: [departureAirportId], references: [id])
  arrivalAirportId        Int?
  arrivalAirport          Airport?      @relation("RouteSegmentArrivalAirport", fields: [arrivalAirportId], references: [id])
  departureMetroStationId Int?
  departureMetroStation   MetroStation? @relation("RouteSegmentDepartureMetroStation", fields: [departureMetroStationId], references: [id])
  arrivalMetroStationId   Int?
  arrivalMetroStation     MetroStation? @relation("RouteSegmentArrivalMetroStation", fields: [arrivalMetroStationId], references: [id])

  itineraryItems ItineraryItem[]

  @@index([transportId])
  @@index([departureStationId])
  @@index([arrivalStationId])
  @@index([departureAirportId])
  @@index([arrivalAirportId])
  @@index([departureMetroStationId])
  @@index([arrivalMetroStationId])
  @@index([departureAt])
}

model Station {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(120)
  latitude   Float
  longitude  Float
  locationId Int
  location   Location @relation(fields: [locationId], references: [id])

  departureSegments RouteSegment[] @relation("RouteSegmentDepartureStation")
  arrivalSegments   RouteSegment[] @relation("RouteSegmentArrivalStation")

  @@index([locationId])
  @@index([name])
}

model Airport {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(120)
  iataCode   String?  @db.VarChar(10)
  icaoCode   String?  @db.VarChar(10)
  latitude   Float
  longitude  Float
  locationId Int
  location   Location @relation(fields: [locationId], references: [id])

  departureSegments RouteSegment[] @relation("RouteSegmentDepartureAirport")
  arrivalSegments   RouteSegment[] @relation("RouteSegmentArrivalAirport")

  @@index([locationId])
  @@index([name])
}

model MetroStation {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(120)
  line       String?  @db.VarChar(80)
  latitude   Float
  longitude  Float
  locationId Int
  location   Location @relation(fields: [locationId], references: [id])

  departureSegments RouteSegment[] @relation("RouteSegmentDepartureMetroStation")
  arrivalSegments   RouteSegment[] @relation("RouteSegmentArrivalMetroStation")

  @@index([locationId])
  @@index([name])
}

model ActivityCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(80)
  description String?  @db.VarChar(200)
  iconUrl     String?  @db.VarChar(500)
  createdAt   DateTime @default(now())

  activities Activity[]
}

model Activity {
  id          Int              @id @default(autoincrement())
  name        String           @db.VarChar(150)
  description String?          @db.Text
  street      String?          @db.VarChar(150)
  latitude    Float
  longitude   Float
  imageUrl    String?          @db.VarChar(500)
  locationId  Int
  location    Location         @relation(fields: [locationId], references: [id])
  categoryId  Int
  category    ActivityCategory @relation(fields: [categoryId], references: [id])
  createdAt   DateTime         @default(now())

  itineraryItems ItineraryItem[]

  @@index([locationId])
  @@index([categoryId])
  @@index([name])
}
