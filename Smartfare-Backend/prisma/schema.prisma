generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int       @id @default(autoincrement())
  email                String    @unique
  passwordHash         String?
  authProvider         String    @default("local")
  sessionId            String?
  resetPasswordToken   String?
  resetPasswordExpires     DateTime?
  isEmailVerified          Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  profile     UserProfile?
  preference  UserPreference?
  itineraries Itinerary[]
  favorites   ItineraryFavorite[]

  @@map("User")
}

model UserProfile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  name      String?
  surname   String?
  city      String?
  street    String?
  avatarUrl String?
  birthDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model UserPreference {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  budgetLevelCode    String   @default("MEDIUM")
  travelStyle        String?
  pace               String?
  preferredTransport String?
  prefersNightlife   Boolean?
  familyFriendly     Boolean?
  maxDailyBudget     Decimal?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user                    User                     @relation(fields: [userId], references: [id])
  userPreferenceInterests UserPreferenceInterest[]
}

model UserPreferenceInterest {
  activityCateegoryId Int @id @default(autoincrement())
  preferenceId        Int

  preference UserPreference @relation(fields: [preferenceId], references: [id])
}

model Location {
  id        Int     @id @default(autoincrement())
  name      String
  province  String?
  cap       String?
  latitude  Float
  longitude Float

  accommodations Accommodation[]
  activities     Activity[]
  airports       Airport[]
  metroStations  MetroStation[]
  stations       Station[]
  itineraries    Itinerary[]
}

model Accommodation {
  id         Int     @id @default(autoincrement())
  name       String
  street     String?
  stars      Int     @default(0)
  latitude   Float
  longitude  Float
  imageUrl   String? @default("https://rpcgfwithmoyezrdeahj.supabase.co/storage/v1/object/public/hotels/hotel.avif")
  locationId Int

  location       Location        @relation(fields: [locationId], references: [id])
  itineraryItems ItineraryItem[]
}

model ActivityCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  iconUrl     String?

  activities Activity[]
}

model Activity {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  street      String?
  latitude    Float
  longitude   Float
  imageUrl    String   @default("https://rpcgfwithmoyezrdeahj.supabase.co/storage/v1/object/public/hotels/hotel.avif")
  locationId  Int
  categoryId  Int
  createdAt   DateTime @default(now())

  location       Location         @relation(fields: [locationId], references: [id])
  category       ActivityCategory @relation(fields: [categoryId], references: [id])
  itineraryItems ItineraryItem[]
}

model Airport {
  id         Int     @id @default(autoincrement())
  name       String
  iataCode   String?
  icaoCode   String?
  latitude   Float
  longitude  Float
  locationId Int

  location       Location        @relation(fields: [locationId], references: [id])
  itineraryItems ItineraryItem[] @relation("ItineraryItem_Airport")
}

model MetroStation {
  id         Int     @id @default(autoincrement())
  name       String
  line       String?
  latitude   Float
  longitude  Float
  locationId Int

  location       Location        @relation(fields: [locationId], references: [id])
  itineraryItems ItineraryItem[] @relation("ItineraryItem_MetroStation")
}

model Station {
  id         Int    @id @default(autoincrement())
  name       String
  latitude   Float
  longitude  Float
  locationId Int

  location       Location        @relation(fields: [locationId], references: [id])
  itineraryItems ItineraryItem[] @relation("ItineraryItem_TrainsStation")
}

model ItineraryVisibility {
  code        String  @id
  name        String
  description String?

  itineraries Itinerary[]
}

model Itinerary {
  id             Int       @id @default(autoincrement())
  name           String
  description    String?
  isPublished    Boolean   @default(false)
  visibilityCode String    @default("PRIVATE")
  publicSlug     String?   @unique
  startDate      DateTime?
  endDate        DateTime?
  aiPrompt       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  userId         Int?
  locationId     Int?
  imageUrl       String @default("https://images.trvl-media.com/place/6046257/dfc1097b-fb0b-4d2f-96f5-15d86e72f134.jpg")

  user       User?               @relation(fields: [userId], references: [id])
  location   Location?           @relation(fields: [locationId], references: [id])
  visibility ItineraryVisibility @relation(fields: [visibilityCode], references: [code])
  favorites  ItineraryFavorite[]
  items      ItineraryItem[]
  
  @@index([userId])
  @@index([updatedAt])
}

model ItineraryFavorite {
  userId      Int
  itineraryId Int
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  itinerary Itinerary @relation(fields: [itineraryId], references: [id])

  @@id([userId, itineraryId])
}

model ItineraryItemType {
  code        String          @id
  label       String
  description String?
  items       ItineraryItem[]
}

model ItineraryItem {
  id              Int       @id @default(autoincrement())
  itineraryId     Int
  itemTypeCode    String
  dayNumber       Int
  orderInt        Int
  note            String?
  plannedStartAt  DateTime?
  plannedEndAt    DateTime?
  groupName       String?
  groupStartAt    DateTime?
  groupEndAt      DateTime?
  activityId      Int?
  accommodationId Int?
  trainsStationId Int?      @map("TrainsStationId")
  metroStationId  Int?      @map("MetroStationId")
  airportId       Int?      @map("AirportId")

  itinerary     Itinerary         @relation(fields: [itineraryId], references: [id])
  itemType      ItineraryItemType @relation(fields: [itemTypeCode], references: [code])
  activity      Activity?         @relation(fields: [activityId], references: [id])
  accommodation Accommodation?    @relation(fields: [accommodationId], references: [id])
  trainsStation Station?          @relation("ItineraryItem_TrainsStation", fields: [trainsStationId], references: [id])
  metroStation  MetroStation?     @relation("ItineraryItem_MetroStation", fields: [metroStationId], references: [id])
  airport       Airport?          @relation("ItineraryItem_Airport", fields: [airportId], references: [id])

  @@unique([itineraryId, dayNumber, orderInt])
  @@index([itineraryId])
  @@index([activityId])
  @@index([accommodationId])
  @@index([trainsStationId])
  @@index([metroStationId])
  @@index([airportId])
}
