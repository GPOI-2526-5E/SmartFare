# Modalità di esecuzione
NODE_ENV=development          # development | production
PORT=3421

# URL per sviluppo locale
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200

# Controlla se abilitare origini preview Vercel (di solito false in locale)
ALLOW_VERCEL_PREVIEW_ORIGINS=false

# Prisma Configuration
DATABASE_URL=
# Use port 5432 for direct connection to the database (needed for migrations)
DIRECT_URL=

# JWT
JWT_EXPIRES_IN=24h
# Genera una chiave lunga e segreta per JWT (es. openssl rand -hex 32)
JWT_SECRET=replace_with_a_strong_random_secret

# Cloudinary (se non usi Cloudinary in locale, lascia vuoto o usa account di test)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google / Gemini / AI keys - lascia come placeholder in locale
GEMINI_API_KEY=
GEMINI_MODEL=

# OAuth (GitHub / Google) - usale solo se configuri redirect per localhost
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ID_CLIENT=

# SMTP — durante lo sviluppo è consigliato usare Mailtrap, Maildev o un SMTP di testing.
# Esempio Mailtrap:
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your_mailtrap_user
# SMTP_PASS=your_mailtrap_pass
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# SendGrid
# - In produzione imposta SENDGRID_API_KEY nelle variabili d'ambiente della piattaforma di deploy.
# - Localmente lascia vuoto per continuare ad usare SMTP/Nodemailer.
SENDGRID_API_KEY=

# Forza l'uso di SendGrid anche in locale (utile per test)
FORCE_SENDGRID=

# Email from address (usato se presente)
EMAIL_FROM=

# Supabase (se non usi supabase in locale lascia vuoto o sostituisci con dev key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Unsplash (se non usi Unsplash in locale lascia vuoto o sostituisci con dev key)
UNSPLASH_ACCESS_KEY=